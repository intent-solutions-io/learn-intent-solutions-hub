# Local dev config — copy to .env (auto-loaded by the Node entry via
# process.loadEnvFile). In production these come from the systemd unit's
# EnvironmentFile (/etc/intentsolutions/learn-hub.env, SOPS-managed) — NOT .env.

# Port the Node service binds (loopback). Caddy reverse-proxies /api/* here.
PORT=8093

# SQLite file that holds the flywheel data (captured questions + practice results).
# Prod: /srv/learn-intentsolutions/data/cohort-hub.db (borg-backed).
DATABASE_PATH=./data/cohort-hub.db

# Bearer token required to call GET /api/questions (the weekly ranking export).
EXPORT_TOKEN=
