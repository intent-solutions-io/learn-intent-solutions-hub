{
  "name": "learn-intent-solutions-hub",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Intent Solutions Learn Hub — CPN cohort learning hub, self-hosted (Hono/Node + SQLite).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.node.ts",
    "build": "tsc",
    "start": "node dist/server.node.js",
    "migrate": "node dist/migrate.js",
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
